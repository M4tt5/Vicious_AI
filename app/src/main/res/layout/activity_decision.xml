<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E0E11"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Titre -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vicious AI"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp"/>

        <!-- Statut -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prêt"
            android:textSize="15sp"
            android:textColor="#AAAAAA"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Spinner upload -->
        <ProgressBar
            android:id="@+id/uploadSpinner"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminate="true"
            app:layout_constraintTop_toBottomOf="@id/statusText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Score texte -->
        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Score de risque : —"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/uploadSpinner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

        <!-- Barre de score -->
        <ProgressBar
            android:id="@+id/scoreProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_risk"
            app:layout_constraintTop_toBottomOf="@id/scoreText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

        <!-- Label tactiques -->
        <TextView
            android:id="@+id/tacticsLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tactiques détectées"
            android:textSize="13sp"
            android:textColor="#888888"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/scoreProgress"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="20dp"/>

        <!-- Badges des tactiques -->
        <LinearLayout
            android:id="@+id/tacticsLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            app:layout_constraintTop_toBottomOf="@id/tacticsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/badgeUrgency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Urgence"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/badge_inactive"/>

            <TextView
                android:id="@+id/badgeAuthority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Autorité"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/badge_inactive"/>

            <TextView
                android:id="@+id/badgeSensitive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Données sensibles"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/badge_inactive"/>

            <TextView
                android:id="@+id/badgeImpersonation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usurpation"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/badge_inactive"/>

        </LinearLayout>

        <!-- Segment en cours -->
        <TextView
            android:id="@+id/segmentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#888888"
            app:layout_constraintTop_toBottomOf="@id/tacticsLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"/>

        <!-- Transcription complète -->
        <TextView
            android:id="@+id/transcriptText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:fontFamily="sans-serif-light"
            android:lineSpacingMultiplier="1.4"
            android:padding="12dp"
            android:background="#1A1A1F"
            app:layout_constraintTop_toBottomOf="@id/segmentText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Raisonnement IA -->
        <TextView
            android:id="@+id/reasoningText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#999999"
            android:lineSpacingMultiplier="1.4"
            android:padding="12dp"
            android:background="#141418"
            app:layout_constraintTop_toBottomOf="@id/transcriptText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Bouton Start -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startRecordingButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Démarrer l'enregistrement"
            android:textAllCaps="false"
            android:textColor="#0E0E11"
            app:backgroundTint="#0A67D1"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/reasoningText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="28dp"/>

        <!-- Bouton Stop -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/stopRecordingButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Arrêter"
            android:textAllCaps="false"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:layout_constraintTop_toBottomOf="@id/startRecordingButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>